# =============================================================
# Azure DevOps Teams Bot - Environment Configuration
# =============================================================

# --- Teams Workflow Webhook ---
# Set up via: Teams channel > Apps > Workflows >
#   "Post to a channel when a webhook request is received"
TEAMS_WEBHOOK_URL=https://prod-xx.westeurope.logic.azure.com/workflows/...

# --- Azure DevOps ---
# Used to verify incoming webhook signatures (optional but recommended)
# Set a secret string when creating DevOps service hooks
DEVOPS_WEBHOOK_SECRET=your-secret-here

# Your ADO org URL e.g. https://dev.azure.com/your-org
DEVOPS_ORG_URL=https://dev.azure.com/your-org
DEVOPS_PROJECT=your-project-name

# --- LLM (optional - leave blank to disable AI enrichment) ---
# Uncomment ONE of the following:

# Option A: Anthropic Claude
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: Azure OpenAI
# LLM_PROVIDER=azure-openai
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Server ---
PORT=3000
# Shared secret to authenticate DevOps → your server (add as HTTP header in service hook config)
WEBHOOK_AUTH_TOKEN=generate-a-strong-random-string
