# Azure DevOps Configuration
DEVOPS_URL=https://dev.azure.com/your-org
DEVOPS_PROJECT=project-name
DEVOPS_PROJECTID=some-guid
DEVOPS_TOKEN=your_pat_token_here

# LLM Configuration (using Ollama for free local models)
# Install Ollama from https://ollama.ai/ and run: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (optional - use instead of Ollama if preferred)
OPENAI_API_KEY=sk-your-openai-key
