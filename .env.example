# Azure DevOps Configuration
DEVOPS_URL=https://dev.azure.com/your-org
DEVOPS_PROJECT=project-name
DEVOPS_PROJECTID=some-guid
DEVOPS_TOKEN=your_pat_token_here

# LLM Configuration (optional - enables AI features)
OPENAI_API_KEY=sk-your-openai-key

# Slack Integration (optional - enables notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
